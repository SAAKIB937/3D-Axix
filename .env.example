# .env.example

# Database credentials
db_host=localhost
db_username=root
db_password=
db_name=your_database_name

# Application settings
app_env=production
app_key=YourAppKeyHere
app_debug=false
app_url=http://yourdomain.com

# Cache settings
cache_driver=file
cache_lifetime=120

# Mail settings
mail_mailer=smtp
mail_host=smtp.mailtrap.io
mail_port=2525
mail_username=
mail_password=

# Other settings
logs_path=/var/log/app.log
